NEXT_PUBLIC_SITE_URL=https://medinaclean.com

# Supabase Free project values. Leave unset for local static review.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REVIEW_BUCKET=review-headshots

# Private admin app. Use strong values in production.
ROSA_ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Calendar invites. Keep disabled unless real credentials are configured.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Public contact links
NEXT_PUBLIC_ROSA_PHONE=
NEXT_PUBLIC_ROSA_WHATSAPP=
NEXT_PUBLIC_ROSA_INSTAGRAM=

# Public analytics. GA4 measurement IDs start with G-.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta Marketing API. Keep live disabled until the ad account, billing, and app permissions are ready.
META_ADS_LIVE_ENABLED=false
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_INSTAGRAM_ACTOR_ID=
META_API_VERSION=v24.0

# Public chat LLM provider. Leave disabled unless a free/local provider is configured.
AI_CHAT_ENABLED=false
AI_CHAT_PROVIDER_CHAIN=gemini,openrouter
AI_CHAT_PROVIDER=
AI_CHAT_MODE=free_api
AI_CHAT_BASE_URL=
AI_CHAT_MODEL=
AI_CHAT_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_CHAT_APP_URL=https://medinaclean.com
AI_CHAT_APP_TITLE=Medina Clean
